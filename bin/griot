#!/usr/bin/env bash
# griot — entry shim for the griot learnings CLI.

set -euo pipefail

ENTRY="$HOME/.agents/cli/griot.ts"

if [[ ! -f "$ENTRY" ]]; then
  echo "griot-shim-error: entry not found at $ENTRY" >&2
  echo "  has the marketplace been installed? run: ~/Sites/local-dev/.bin/install-marketplace.sh" >&2
  exit 2
fi

exec node "$ENTRY" "$@"
