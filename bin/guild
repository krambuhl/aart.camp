#!/usr/bin/env bash
# guild — entry shim for the guild antagonist-substrate CLI.

set -euo pipefail

ENTRY="$HOME/.agents/cli/guild.ts"

if [[ ! -f "$ENTRY" ]]; then
  echo "guild-shim-error: entry not found at $ENTRY" >&2
  echo "  has the marketplace been installed? run: ~/Sites/local-dev/.bin/install-marketplace.sh" >&2
  exit 2
fi

exec node "$ENTRY" "$@"
