#!/usr/bin/env bash
# loom — entry shim for the loom project-substrate CLI.

set -euo pipefail

ENTRY="$HOME/.agents/cli/loom.ts"

if [[ ! -f "$ENTRY" ]]; then
  echo "loom-shim-error: entry not found at $ENTRY" >&2
  echo "  has the marketplace been installed? run: ~/Sites/local-dev/.bin/install-marketplace.sh" >&2
  exit 2
fi

exec node "$ENTRY" "$@"
