#!/usr/bin/env bash
# draft — entry shim for the draft planning CLI.
# Resolves to the marketplace-installed CLI via ~/.agents/cli/, which
# the marketplace's install.sh symlinks back into ~/Sites/agents/cli/.

set -euo pipefail

ENTRY="$HOME/.agents/cli/draft.ts"

if [[ ! -f "$ENTRY" ]]; then
  echo "draft-shim-error: entry not found at $ENTRY" >&2
  echo "  has the marketplace been installed? run: ~/Sites/local-dev/.bin/install-marketplace.sh" >&2
  exit 2
fi

exec node "$ENTRY" "$@"
